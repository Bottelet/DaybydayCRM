APP_ENV=testing
APP_DEBUG=true
APP_KEY=base64:xxx          # not used in tests, can be fixed or replaced

CACHE_STORE=array
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

DB_CONNECTION=mysql        # Don't use 'mariadb' for the driver; use 'mysql'
DB_HOST=127.0.0.1          # Point to service in GH Actions
DB_PORT=3306
DB_DATABASE=daybyday_test_%d  # Enable parallel DBs: will use daybyday_test_1, 2, etc.
DB_USERNAME=root
DB_PASSWORD=password
