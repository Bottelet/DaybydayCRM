{
    "name": "bottelet/daybyday-crm",
    "description": "DaybydayCRM is a free, open-source and self-hosted CRM platform based of Laravel",
    "keywords": [
        "laravel",
        "CRM",
        "customer management",
        "Lead management",
        "customer relationship management"
    ],
    "authors": [
        {
            "name": "Casper Bottelet",
            "email": "cbottelet@gmail.com"
        }
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.3",
        "aws/aws-sdk-php": ">=3.376.4",
        "elasticsearch/elasticsearch": ">=9.3",
        "google/apiclient": ">=2.19.2",
        "laravel/cashier": ">=16.5.1",
        "laravel/framework": "^12.56",
        "laravel/helpers": ">=1.8.3",
        "laravel/legacy-factories": ">=1.4.2",
        "laravel/ui": ">=4.6.3",
        "league/flysystem-aws-s3-v3": ">=3.32",
        "mews/purifier": ">=3.4.3",
        "predis/predis": ">=3.4.2",
        "ramsey/uuid": ">=4.9.2",
        "spatie/dropbox-api": ">=1.24",
        "yajra/laravel-datatables-oracle": ">=12.7"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": ">=4.2.4",
        "brianium/paratest": "^7.20",
        "driftingly/rector-laravel": ">=2.2",
        "fakerphp/faker": "^1.24.1",
        "laravel/dusk": ">=8.5",
        "laravel/pint": ">=1.29",
        "laravel/tinker": ">=3",
        "mockery/mockery": ">=1.6.12",
        "nunomaduro/collision": ">=8.9.3",
        "nunomaduro/pao": "^0.1",
        "phpunit/phpunit": ">=12.5.16",
        "rector/rector": ">=2.4",
        "symfony/css-selector": ">=7.4.8",
        "symfony/dom-crawler": ">=7.4.8"
    },
    "autoload": {
        "files": [
            "app/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "aargh": "php artisan config:clear && php artisan cache:clear && php artisan route:clear && php artisan view:clear",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
