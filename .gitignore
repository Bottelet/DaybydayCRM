######################################################################
# Laravel & PHP Project .gitignore (Professionalized)
######################################################################

# === Composer & Vendor ===
/vendor/

# === Node & Frontend ===
/node_modules/
bower_components/

# === IDE & Editor Files ===
.idea/
/.idea/
/.vscode/
/.phpintel/
/.phpactor.json
/.phpunit*
/.fleet/
/.zed/
/.nova/
Thumbs.db
.DS_Store

# === Environment & Config ===
.env
.env.backup
.env.production
.env.testing
Homestead.yaml
Homestead.json
/auth.json

# === Build & Asset Artifacts ===
public/build/
public/hot/
public/storage/
storage/pail/
mix-manifest.json

# === Cache & Logs ===
*.log
/.phpunit.cache
/.phpunit.result.cache
_ide_helper.php
stan.txt
todo.txt

# === Database & Docker ===
.docker/flarepoint-db/*
storage/*.key

# === Miscellaneous ===
/storage/framework/
/storage/logs/
/storage/app/

# === PHP Tools & Static Analysis ===
.php_cs.cache

# === Laravel Debugbar ===
storage/debugbar/

# === Custom Exclusions ===
# (Add any project-specific ignores below)
